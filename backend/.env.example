# MongoDB Connection
# Local:
# MONGODB_URI=mongodb://localhost:27017/thinkclash
# Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thinkclash?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/thinkclash

# JWT Secret (generate a secure random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
